<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PEACMark Issuance Email</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,700;1,6..72,400&family=Public+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        background: #d8d4d4;
        font-family: "Public Sans", sans-serif;
      }
      * {
        box-sizing: border-box;
      }
      .page {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 40px 20px 60px;
        min-height: 100vh;
      }
      .email-wrap {
        width: 600px;
        max-width: 100%;
        background: #f5f3f3;
        border-radius: 6px;
        overflow: hidden;
        box-shadow:
          0 2px 6px rgba(0, 0, 0, 0.08),
          0 16px 48px -16px rgba(80, 10, 10, 0.22);
      }
      a {
        color: #8b1a1f;
      }
      a:hover {
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="email-wrap">
        <!-- ═══ HEADER ═══ -->
        <div
          style="
            background: #fff;
            padding: 24px 36px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid #eae6e6;
          "
        >
          <!-- PEAC logo -->
          <img src="PEAC LOGO1.png" alt="PEAC – Private Education Assistance Committee" style="height: 52px; width: auto; display: block;" />
          <!-- CertCheck logo -->
          <img src="Cert Check logo1.png" alt="CertCheck" style="height: 44px; width: auto; display: block;" />
        </div>

        <!-- ═══ BODY AREA ═══ -->
        <div style="padding: 22px 28px 24px; background: #f5f3f3">
          <!-- Card with dark red border -->
          <div
            style="
              background: #fff;
              border: 3px solid #8b1a1f;
              border-radius: 12px;
              padding: 32px 36px 120px;
              position: relative;
              overflow: hidden;
            "
          >
            <!-- Ghost watermark badge (bottom-right) -->
            <div
              style="
                position: absolute;
                bottom: -28px;
                right: -22px;
                opacity: 0.09;
                pointer-events: none;
              "
              aria-hidden="true"
            >
              <svg width="190" height="190" viewBox="0 0 200 200" fill="none">
                <path
                  d="M100 12l76 44v88L100 188 24 144V56L100 12z"
                  stroke="#8B1A1F"
                  stroke-width="10"
                  fill="none"
                />
                <path
                  d="M100 34l60 34.6v69.4L100 172.6 40 138V68.6L100 34z"
                  fill="#8B1A1F"
                />
                <path
                  d="M68 100l20 20 46-44"
                  stroke="#F5F3F3"
                  stroke-width="12"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>

            <!-- Eyebrow -->
            <div
              style="
                font-family: &quot;Public Sans&quot;, sans-serif;
                font-size: 12px;
                font-weight: 700;
                color: #b8943f;
                font-style: italic;
                margin-bottom: 8px;
                letter-spacing: 0.01em;
              "
            >
              Certification Issued
            </div>

            <!-- Headline -->
            <h1
              style="
                margin: 0 0 22px;
                font-family: &quot;Public Sans&quot;, sans-serif;
                font-size: 28px;
                line-height: 1.16;
                font-weight: 800;
                color: #1a1818;
                letter-spacing: -0.02em;
                max-width: 420px;
              "
            >
              Congratulations — your PEACMark<br />is now live.
            </h1>

            <!-- Greeting -->
            <p
              style="
                font-family: &quot;Public Sans&quot;, sans-serif;
                font-size: 14.5px;
                line-height: 1.6;
                color: #2e2a2a;
                margin: 0 0 14px;
              "
            >
              Good day,
              <strong style="color: #1a1818; font-weight: 700"
                >San Pedro Calungsod Education Center</strong
              >
            </p>

            <!-- Para 1 -->
            <p
              style="
                font-family: &quot;Public Sans&quot;, sans-serif;
                font-size: 14px;
                line-height: 1.65;
                color: #3c3838;
                margin: 0 0 14px;
                text-wrap: pretty;
              "
            >
              We are pleased to inform you that your school's certification
              status is now verifiable through the PEAC CertCheck facility.
            </p>

            <!-- Para 2 -->
            <p
              style="
                font-family: &quot;Public Sans&quot;, sans-serif;
                font-size: 14px;
                line-height: 1.65;
                color: #3c3838;
                margin: 0 0 16px;
                text-wrap: pretty;
              "
            >
              You may access CertCheck through
              <a href="[insert url]">[insert url]</a>, where you can also
              download your school's PEAC certification badge called PEACMark.
              Please refer to the attached Guidelines on the Use of the PEACMark
              for information on its proper use.
            </p>

            <!-- CTA 1: School access -->
            <div style="margin: 0 0 24px">
              <a
                href="[insert url]"
                style="
                  display: inline-block;
                  background: #8b1a1f;
                  color: #fff;
                  font-family: &quot;Public Sans&quot;, sans-serif;
                  font-size: 14px;
                  font-weight: 700;
                  text-decoration: none;
                  padding: 12px 28px;
                  border-radius: 7px;
                  letter-spacing: 0.01em;
                  white-space: nowrap;
                "
                >Access PEAC CertCheck →</a
              >
            </div>

            <!-- Para 3 -->
            <p
              style="
                font-family: &quot;Public Sans&quot;, sans-serif;
                font-size: 14px;
                line-height: 1.65;
                color: #3c3838;
                margin: 0 0 16px;
                text-wrap: pretty;
              "
            >
              The public may likewise verify your school's certification status
              by entering your DepEd School ID on the
              <a href="[insert url]">[insert url]</a>, or by scanning the QR
              Code embedded in the PEACMark.
            </p>

            <!-- CTA 2: Public access -->
            <div style="margin: 0 0 24px">
              <a
                href="[insert url]"
                style="
                  display: inline-block;
                  background: #fff;
                  color: #8b1a1f;
                  font-family: &quot;Public Sans&quot;, sans-serif;
                  font-size: 14px;
                  font-weight: 700;
                  text-decoration: none;
                  padding: 11px 24px;
                  border-radius: 7px;
                  border: 2px solid #8b1a1f;
                  letter-spacing: 0.01em;
                "
                >Verify School Certification →</a
              >
            </div>

            <!-- Para 4 -->
            <p
              style="
                font-family: &quot;Public Sans&quot;, sans-serif;
                font-size: 14px;
                line-height: 1.65;
                color: #3c3838;
                margin: 0;
                text-wrap: pretty;
              "
            >
              Thank you for pursuing PEAC certification and for your commitment
              to ensuring compliance with established quality standards in
              education.
            </p>
          </div>
          <!-- /card -->
        </div>

        <!-- ═══ FOOTER ═══ -->
        <div
          style="
            background: #fff;
            padding: 28px 36px 32px;
            text-align: center;
            border-top: 1px solid #eae6e6;
          "
        >
          <!-- Address + unsubscribe -->
          <p
            style="
              font-family: &quot;Public Sans&quot;, sans-serif;
              font-size: 12px;
              color: #9a9494;
              line-height: 1.6;
              margin: 0 0 6px;
            "
          >
            Company Inc. 7-11 Commercial Ct, Belfast BT1 2NB
          </p>
          <p
            style="
              font-family: &quot;Public Sans&quot;, sans-serif;
              font-size: 12px;
              color: #9a9494;
              margin: 0 0 20px;
            "
          >
            Don't like these emails?
            <a href="#" style="color: #9a9494">Unsubscribe.</a>
          </p>

          <!-- Social icons -->
          <div
            style="
              display: flex;
              align-items: center;
              justify-content: center;
              gap: 10px;
              margin-bottom: 20px;
            "
          >
            <!-- Facebook -->
            <a
              href="#"
              style="
                display: flex;
                align-items: center;
                justify-content: center;
                width: 34px;
                height: 34px;
                border-radius: 50%;
                background: #3b5998;
                text-decoration: none;
              "
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff">
                <path
                  d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                />
              </svg>
            </a>
            <!-- Instagram -->
            <a
              href="#"
              style="
                display: flex;
                align-items: center;
                justify-content: center;
                width: 34px;
                height: 34px;
                border-radius: 50%;
                background: #c13584;
                text-decoration: none;
              "
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#fff"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1" fill="#fff" stroke="none" />
              </svg>
            </a>
          </div>

          <!-- Copyright -->
          <p
            style="
              font-family: &quot;Public Sans&quot;, sans-serif;
              font-size: 12px;
              color: #9a9494;
              margin: 0 0 20px;
            "
          >
            © 2026 PEAC - IMS. All rights reserved.
          </p>

          <!-- Powered by Rakso CT -->
          <div
            style="
              display: inline-flex;
              flex-direction: column;
              align-items: center;
              gap: 4px;
            "
          >
            <span
              style="
                font-family: &quot;Public Sans&quot;, sans-serif;
                font-size: 10.5px;
                color: #b0aaaa;
                letter-spacing: 0.03em;
              "
              >Powered by Rakso CT</span
            >
            <!-- Rakso CT logo placeholder -->
            <div style="display: flex; align-items: center; gap: 7px">
              <svg width="26" height="26" viewBox="0 0 36 36" fill="none">
                <rect width="36" height="36" rx="6" fill="#1A6EBD" />
                <path
                  d="M10 26V10h8a6 6 0 0 1 0 12h-8"
                  stroke="#fff"
                  stroke-width="2.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <path
                  d="M18 22l6 4"
                  stroke="#fff"
                  stroke-width="2.4"
                  stroke-linecap="round"
                />
              </svg>
              <span
                style="
                  font-family: &quot;Public Sans&quot;, sans-serif;
                  font-size: 17px;
                  font-weight: 800;
                  color: #1a6ebd;
                  letter-spacing: -0.01em;
                "
                >RAKSO</span
              >
              <span
                style="
                  font-family: &quot;Public Sans&quot;, sans-serif;
                  font-size: 12px;
                  font-weight: 700;
                  color: #4aa8d8;
                  letter-spacing: 0.08em;
                  margin-top: 2px;
                "
                >CT</span
              >
            </div>
          </div>
        </div>
      </div>
      <!-- /email-wrap -->
    </div>
    <!-- /page -->
  </body>
</html>
